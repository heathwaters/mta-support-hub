# Supabase (for VA login)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MTA MySQL (read-only)
MTA_MYSQL_HOST=
MTA_MYSQL_PORT=3306
MTA_MYSQL_USER=
MTA_MYSQL_PASSWORD=
MTA_MYSQL_DATABASE=
MTA_MYSQL_SSL=true

# MTT MySQL (read-only)
MTT_MYSQL_HOST=
MTT_MYSQL_PORT=3306
MTT_MYSQL_USER=
MTT_MYSQL_PASSWORD=
MTT_MYSQL_DATABASE=
MTT_MYSQL_SSL=true

# MTA CMS API (write actions)
CMS_MTA_API_BASE_URL=
CMS_MTA_API_APP_KEY=
CMS_MTA_API_USERNAME=
CMS_MTA_API_PASSWORD=

# MTT CMS API (write actions)
CMS_MTT_API_BASE_URL=
CMS_MTT_API_APP_KEY=
CMS_MTT_API_USERNAME=
CMS_MTT_API_PASSWORD=

# Upstash Redis (rate limiting — optional in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# CORS allowed origins (comma-separated — optional, defaults to same-origin)
ALLOWED_ORIGINS=

# Set to "true" to skip env validation during build
SKIP_ENV_VALIDATION=
